{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "test-case.schema.json",
  "title": "Test case",
  "description": "Schema for a single test case YAML file under test-cases/<suite>/<ID>.yaml",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "suite", "priority", "status", "steps"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TC-\\d{4,}$",
      "description": "Unique identifier, e.g. TC-0001. Must match the file name."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "suite": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Lowercase kebab-case suite name. Must match the folder the file lives in."
    },
    "priority": {
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {
      "enum": ["draft", "active", "deprecated"]
    },
    "automated": {
      "type": "boolean"
    },
    "owner": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "linked_ticket": {
      "type": "string",
      "description": "Optional external ticket reference, e.g. a Jira ID."
    },
    "preconditions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action"],
        "properties": {
          "action": { "type": "string", "minLength": 1 },
          "expected": { "type": "string" }
        }
      }
    },
    "created_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
